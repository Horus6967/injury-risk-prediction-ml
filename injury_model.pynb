        "import shap\n",
        "\n",
        "explainer = shap.TreeExplainer(model)\n",
        "\n",
        "shap_values = explainer(X_test, check_additivity=False)\n",
        "\n",
        "# SELECT CLASS 1 (injury class)\n",
        "shap.plots.beeswarm(shap_values[..., 1], max_display=10)"
